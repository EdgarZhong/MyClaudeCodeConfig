{
  "permissions": {
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rd:*)",
      "Bash(rmdir:*)",
      "Bash(Remove-Item:*)",
      "Bash(format:*)",
      "Bash(diskpart:*)",
      "Bash(reg delete:*)",
      "Bash(net user:*)",
      "Bash(shutdown:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File 'C:/Users/18518/.claude/git-autocommit.ps1'",
            "async": true
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
