{
  "skipDangerousModePermissionPrompt": true,
  "model": "opus",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rd:*)",
      "Bash(rmdir:*)",
      "Bash(Remove-Item:*)",
      "Bash(format:*)",
      "Bash(diskpart:*)",
      "Bash(reg delete:*)",
      "Bash(net user:*)",
      "Bash(shutdown:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [{
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [{
        "type": "command",
        "command": "powershell -Command \"cd $env:USERPROFILE\\.claude; if (git status --porcelain) { git add -A; git commit -m 'auto: claude config update' }\""
      }]
    }]
  }
}